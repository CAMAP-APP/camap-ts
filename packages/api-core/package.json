    "@types/node": "^20.12.4",
    "@types/node-sass": "^4.11.7",
    "@types/nodemailer": "^6.4.14",
    "@types/passport-http-bearer": "^1.0.41",
    "@types/passport-jwt": "^4.0.1",
    "@types/rimraf": "^3.0.2",
    "@types/sharp": "^0.31.1",
    "@types/supertest": "^6.0.2",
    "@types/yup": "^0.29.14",
